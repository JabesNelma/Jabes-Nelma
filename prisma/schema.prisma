// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  imageUrl    String   @db.Text
  projectUrl  String?  @db.Text
  repoUrl     String?  @db.Text
  type        String   // "client" or "learning"
  tags        String   @db.Text // JSON string array
  featured    Boolean  @default(false)
  year        Int      @default(2026) // Project year
  isPinned    Boolean  @default(false) // Pin/unpin project
  order       Int      @default(0) // Sort order
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model About {
  id        String   @id @default(cuid())
  bio       String   @db.Text
  avatarUrl String?
  email     String
  phone     String?
  location  String?
  resumeUrl String?
  updatedAt DateTime @updatedAt
}

model CurrentFocus {
  id          String   @id @default(cuid())
  title       String
  description String
  icon        String?
  updatedAt   DateTime @updatedAt
}

model SocialLink {
  id       String   @id @default(cuid())
  platform String
  url      String
  icon     String?
  order    Int      @default(0)
}

model Skill {
  id       String   @id @default(cuid())
  name     String
  category String
  level    Int      // 1-5
  icon     String?
  order    Int      @default(0)
}

model SiteConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  ip        String?
  userAgent String?
  referrer  String?
  createdAt DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model LegacyAboutParagraph {
  id        String   @id @default(cuid())
  order     Int      @unique
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LegacyPrinciple {
  id        String   @id @default(cuid())
  order     Int      @unique
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LegacyFocusItem {
  id          String   @id @default(cuid())
  order       Int      @unique
  title       String
  description String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LegacyContactLink {
  id          String   @id @default(cuid())
  order       Int      @unique
  platform    String
  url         String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
